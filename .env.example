## Application
## -------------

# Node environment: development | production | test
NODE_ENV=development

# HTTP port the NestJS app will listen on
PORT=3000


## Database (PostgreSQL)
## ----------------------

# Hostname or IP of the Postgres server
DB_HOST=localhost

# Port of the Postgres server
DB_PORT=5432

# Database username
DB_USERNAME=postgres

# Database password
DB_PASSWORD=postgres

# Database name
DB_NAME=building_booking


## TypeORM options
## ----------------

# Auto sync schema with entities.
# WARNING: should be false in production; use migrations instead.
TYPEORM_SYNCHRONIZE=true

# Enable SQL logging (queries, errors, schema changes) in dev.
TYPEORM_LOGGING=true

